{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai.rj11.io/schemas/benchmark-config.schema.json",
  "title": "11ai benchmark configuration",
  "type": "object",
  "required": ["schemaVersion", "artifactId", "status", "benchmarkId", "mode", "runStrategy", "contentMode", "evidenceSurfaces"],
  "properties": {
    "schemaVersion": { "const": 2 },
    "artifactId": { "type": "string", "minLength": 1 },
    "status": { "enum": ["draft", "complete", "stale", "superseded"] },
    "benchmarkId": { "type": "string", "minLength": 1 },
    "mode": { "enum": ["single-app", "isolated"] },
    "runStrategy": { "enum": ["folder", "branch", "worktree", "repository"] },
    "baselineRef": { "type": ["string", "null"] },
    "dependencyPolicy": {
      "type": "object",
      "required": ["mode"],
      "properties": { "mode": { "enum": ["frozen", "allowlist", "free"] }, "allow": { "type": "array", "items": { "type": "string" } } },
      "additionalProperties": true
    },
    "contentMode": { "enum": ["static", "fixtures", "dynamic", "external", "user-managed"] },
    "evidenceSurfaces": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } },
    "canonicalUrls": { "type": "object", "additionalProperties": { "type": "string" } }
  },
  "additionalProperties": true
}
