{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai.rj11.io/schemas/judge.schema.json",
  "title": "11ai AI or human judge artifact",
  "type": "object",
  "required": ["schemaVersion", "artifactId", "status", "judgeId", "judgeType", "cycleId", "rubricSha", "evidenceSha", "runs", "overallRanking"],
  "properties": {
    "schemaVersion": { "const": 2 },
    "artifactId": { "type": "string" },
    "status": { "enum": ["draft", "complete", "superseded"] },
    "judgeId": { "type": "string" },
    "judgeType": { "enum": ["ai", "human"] },
    "judgeModel": { "type": ["string", "null"] },
    "cycleId": { "type": "string" },
    "rubricSha": { "type": "string" },
    "evidenceSha": { "type": "string" },
    "identityBlinded": { "type": "boolean" },
    "runs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["anonymizedAs", "dimensions"],
        "properties": {
          "anonymizedAs": { "type": "string" },
          "dimensions": { "type": "object", "additionalProperties": { "type": "object", "required": ["score", "justification"], "properties": { "score": { "type": "number", "minimum": 1, "maximum": 10 }, "justification": { "type": "string", "minLength": 1 } }, "additionalProperties": true } }
        },
        "additionalProperties": true
      }
    },
    "overallRanking": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } }
  },
  "additionalProperties": true
}
